<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom|center">

    <LinearLayout
        android:id="@+id/left_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/control"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/layout_switch_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/custom_border"
            android:gravity="center"
            android:text="1"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <com.happyworldgames.keyboard.ShiftKeyView
            android:id="@+id/shift_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/shift" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/control"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/custom_border"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/line1"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/pos1"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <View
                android:id="@+id/pos2"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <View
                android:id="@+id/pos3"
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/line2"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/pos4"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <View
                android:id="@+id/pos5"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_center" />

            <View
                android:id="@+id/pos6"
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/line3"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/pos7"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <View
                android:id="@+id/pos8"
                android:layout_width="40dp"
                android:layout_height="40dp" />

            <View
                android:id="@+id/pos9"
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/backspace"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/control"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:id="@+id/backspace_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/backspace"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/space_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/custom_border"
            android:gravity="center"
            android:text="˽"
            android:textColor="#000000"
            android:textSize="20sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>