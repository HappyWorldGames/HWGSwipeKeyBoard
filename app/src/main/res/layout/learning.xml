<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/instructionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/learning"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/learn_welcome"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructionTitle" />

    <EditText
        android:id="@+id/editText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:hint="@string/for_test"
        android:importantForAutofill="no"
        android:inputType="textMultiLine"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/instructionText" />

    <TextView
        android:id="@+id/visualizerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/visualizer_label"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="@id/visualizerContainer"
        app:layout_constraintTop_toBottomOf="@id/editText" />

    <FrameLayout
        android:id="@+id/visualizerContainer"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/custom_border"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/visualizerLabel">

        <GridLayout
            android:id="@+id/visualizerGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:columnCount="3"
            android:rowCount="3">

            <TextView android:id="@+id/vPos1" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="1" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos2" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="2" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos3" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="3" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos4" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="4" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos5" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="@drawable/circle_center" android:gravity="center" android:text="5" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos6" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="6" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos7" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="7" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos8" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="8" android:textColor="#40000000" tools:ignore="HardcodedText" />
            <TextView android:id="@+id/vPos9" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="2dp" android:background="#20000000" android:gravity="center" android:text="9" android:textColor="#40000000" tools:ignore="HardcodedText" />

        </GridLayout>

        <ImageView
            android:id="@+id/gestureArrow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:alpha="0.8"
            android:visibility="gone"
            android:contentDescription="@null"
            app:srcCompat="@android:drawable/ic_menu_send"
            app:tint="@color/black" />

    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/nextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/learningProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/nextButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>