<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settings_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/show_buttons_settings"
                android:textSize="20sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/checkbox_backspace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_backspace" />

            <CheckBox
                android:id="@+id/checkbox_space"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_space" />

            <CheckBox
                android:id="@+id/checkbox_layout_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_layout_switch" />

            <CheckBox
                android:id="@+id/checkbox_shift"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_shift" />

            <CheckBox
                android:id="@+id/checkbox_symbols_on_keys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/show_symbols_on_keys" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#CCCCCC" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/vibration_settings"
                android:textSize="20sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/checkbox_vibration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/enable_vibration" />

            <CheckBox
                android:id="@+id/checkbox_vibration_different"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/different_vibration_per_zone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/vibration_strength" />

            <SeekBar
                android:id="@+id/seekbar_vibration_strength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="255"
                android:progress="150" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/vibration_duration" />

            <SeekBar
                android:id="@+id/seekbar_vibration_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="30" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#CCCCCC" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/settings_management"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/export_settings_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/export_settings" />

            <Button
                android:id="@+id/import_settings_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/import_settings" />

            <Button
                android:id="@+id/reset_settings_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="#FF5252"
                android:text="@string/reset_settings"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>